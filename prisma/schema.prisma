// Uzhavar Thozhan — data model covering all 13 features.
// Run `npx prisma migrate dev` after setting DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Farmer accounts + login
model Farmer {
  id            String   @id @default(cuid())
  name          String
  phone         String   @unique
  email         String?  @unique
  passwordHash  String
  village       String?
  district      String?
  state         String?
  pinCode       String?
  createdAt     DateTime @default(now())

  lands         Land[]
  insurances    Insurance[]
  claims        InsuranceClaim[]
  loans         Loan[]
  orders        Order[]
  listings      MarketListing[]
  consultations Consultation[]
  equipmentBookings EquipmentBooking[]
}

// 2. Land + soil profile, used for crop recommendations
model Land {
  id            String   @id @default(cuid())
  farmer        Farmer   @relation(fields: [farmerId], references: [id])
  farmerId      String
  name          String
  areaAcres     Float
  soilType      String   // e.g. Red loam, Black cotton, Alluvial, Sandy, Clay
  nitrogen      Float?
  phosphorus    Float?
  potassium     Float?
  ph            Float?
  latitude      Float?
  longitude     Float?
  cropPlans     CropPlan[]
}

model Crop {
  id                String   @id @default(cuid())
  name              String
  tamilName         String?
  idealSoilTypes    String[] // matches Land.soilType values
  idealSeason       String   // Kharif / Rabi / Zaid / Tamil season name
  waterRequirement  String?
  fertilizerNotes   String?
  cropPlans         CropPlan[]
}

model CropPlan {
  id           String   @id @default(cuid())
  land         Land     @relation(fields: [landId], references: [id])
  landId       String
  crop         Crop     @relation(fields: [cropId], references: [id])
  cropId       String
  sownOn       DateTime?
  expectedHarvest DateTime?
  status       String   @default("planned") // planned, growing, harvested
}

// 3. Government schemes / subsidies
model GovtScheme {
  id           String   @id @default(cuid())
  title        String
  description  String
  benefitAmount String?
  eligibility  String
  applyUrl     String?
  state        String?  // null = central/national scheme
}

// 4 & 5. Weather + seasonal suggestions are largely served live from
// external APIs (see /app/api/weather and /app/api/seasonal) and are
// not persisted, aside from optional caching (below).
model WeatherCache {
  id        String   @id @default(cuid())
  pinCode   String
  payload   Json
  fetchedAt DateTime @default(now())
}

// 6 & 7. Insurance + claims
model InsurancePlan {
  id           String   @id @default(cuid())
  name         String
  cropType     String
  premiumRate  Float    // % of sum insured
  coverage     String
  insurances   Insurance[]
}

model Insurance {
  id           String   @id @default(cuid())
  farmer       Farmer   @relation(fields: [farmerId], references: [id])
  farmerId     String
  plan         InsurancePlan @relation(fields: [planId], references: [id])
  planId       String
  sumInsured   Float
  premiumPaid  Float
  season       String
  status       String   @default("active") // active, expired, cancelled
  createdAt    DateTime @default(now())
  claims       InsuranceClaim[]
}

model InsuranceClaim {
  id           String   @id @default(cuid())
  farmer       Farmer   @relation(fields: [farmerId], references: [id])
  farmerId     String
  insurance    Insurance @relation(fields: [insuranceId], references: [id])
  insuranceId  String
  reason       String   // e.g. flood, drought, pest attack
  description  String
  photoUrls    String[]
  status       String   @default("submitted") // submitted, under_review, approved, rejected, paid
  submittedAt  DateTime @default(now())
  resolvedAt   DateTime?
}

// 8. Expert video consultations
model ExpertDoctor {
  id            String   @id @default(cuid())
  name          String
  specialty     String   // e.g. Plant pathology, Soil science, Pest control
  languages     String[]
  rating        Float    @default(0)
  consultations Consultation[]
}

model Consultation {
  id          String   @id @default(cuid())
  farmer      Farmer   @relation(fields: [farmerId], references: [id])
  farmerId    String
  expert      ExpertDoctor @relation(fields: [expertId], references: [id])
  expertId    String
  scheduledAt DateTime
  durationMin Int      @default(15)
  roomId      String?  // video SDK room/session id
  status      String   @default("scheduled") // scheduled, completed, cancelled
  notes       String?
}

// 9 & 13. Products: pesticides, medicines, seeds, other inputs
model Product {
  id          String   @id @default(cuid())
  name        String
  category    String   // pesticide, fertilizer, medicine, seed, other
  brand       String?
  price       Float
  unit        String   // e.g. kg, litre, packet
  stock       Int      @default(0)
  imageUrl    String?
  orderItems  OrderItem[]
}

model Order {
  id          String   @id @default(cuid())
  farmer      Farmer   @relation(fields: [farmerId], references: [id])
  farmerId    String
  items       OrderItem[]
  totalAmount Float
  status      String   @default("pending") // pending, paid, shipped, delivered, cancelled
  createdAt   DateTime @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Float
}

// 10. Direct-to-market selling (farmer -> buyer / govt / private)
model MarketListing {
  id           String   @id @default(cuid())
  farmer       Farmer   @relation(fields: [farmerId], references: [id])
  farmerId     String
  produceName  String
  quantityKg   Float
  pricePerKg   Float
  harvestDate  DateTime?
  status       String   @default("available") // available, reserved, sold
  buyerType    String?  // individual, private_company, government
  createdAt    DateTime @default(now())
}

// 11. Loans
model LoanScheme {
  id             String   @id @default(cuid())
  name           String
  provider       String   // e.g. NABARD, State Bank, Cooperative Bank
  interestRate   Float
  maxAmount      Float
  tenureMonths   Int
  loans          Loan[]
}

model Loan {
  id           String   @id @default(cuid())
  farmer       Farmer   @relation(fields: [farmerId], references: [id])
  farmerId     String
  scheme       LoanScheme @relation(fields: [schemeId], references: [id])
  schemeId     String
  amountRequested Float
  amountApproved  Float?
  status       String   @default("submitted") // submitted, under_review, approved, rejected, disbursed, closed
  appliedAt    DateTime @default(now())
}

// 12. Equipment / robot rental booking
model Equipment {
  id           String   @id @default(cuid())
  name         String   // e.g. Drone sprayer, Tiller, Harvester robot
  type         String
  dailyRate    Float
  available    Boolean  @default(true)
  bookings     EquipmentBooking[]
}

model EquipmentBooking {
  id           String   @id @default(cuid())
  farmer       Farmer   @relation(fields: [farmerId], references: [id])
  farmerId     String
  equipment    Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId  String
  startDate    DateTime
  endDate      DateTime
  totalCost    Float
  status       String   @default("requested") // requested, confirmed, in_progress, completed, cancelled
}
